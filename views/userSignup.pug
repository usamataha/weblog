extends layout

block content

  form(method="post" autocomplete="on")

    fieldset(class= "row")

      legend
        h2(locKey="Sign up") Sign up
      
      label(class="formLabels" for="user_name" locKey="User Name:") User Name:
      input(class="formInputs" id="user_name", type="text", placeholder="User Name" name="user_name" required)

      label(class="formLabels" for="email" locKey="Email:") Email:
      input(class="formInputs" id="email", type="email", placeholder="Email" name="email" required)

      label(class="formLabels" for="password" locKey="Password:") Password:
      input(class="formInputs" id="password", type="password", placeholder="Password" name="password" required)

      label(class="formLabels" for="confirm_password" locKey="Confirm Password:") Confirm Password:
      input(class="formInputs" id="confirm_password", type="password", placeholder="Confirm Password" name="confirm_password" required)

      div(class="formButtons")
        button(id="submit" type="submit" locKey="Submit") Submit

      div(class="formErrors")
        if validatorErrors
          ul(class = "error")
            for error in validatorErrors
              li!= error.msg

