extends layout

block content

    form(method="post" autocomplete="on")

        fieldset(class="row")

            legend
                h2 #{title}
            
            label(class="formLabels" for="title") Title:
            input(class="formInputs" id="title", type="text", placeholder="Book Title" name="title" required value=`${book.title}`)

            label(class="formLabels" for="author") Author:
            input(class="formInputs" id="author", type="text", placeholder="Book Author" name="author" required value=`${book.author}`)

            label(class="formLabels" for="summary") Summary:
            textarea(class="formInputs" id="summary", type="text", placeholder="Book Summary" name="summary" required) #{book.summary}

            label(class="formLabels" for="book_url") Book URL:
            input(class="formInputs" id="book_url", type="url", placeholder="Book URL" name="book_url" required value=`${book.book_url}`)

            label(class="formLabels" for="date_published") Date Of Publication:
            input(class="formInputs" id="date_published", type="date", placeholder="dd-mm-yyyy" name="date_published" value=`${book.date_published.toISOString().split('T')[0]}`)

            label(class="formLabels" for="cover_s_url") Book Cover (Small) URL:
            input(class="formInputs" id="cover_s_url", type="url", placeholder="Book Cover (Small) URL" name="cover_s_url" required value=`${book.cover_s_url}`)

            label(class="formLabels" for="cover_l_url") Book Cover (Large) URL:
            input(class="formInputs" id="cover_l_url", type="url", placeholder="Book Cover (Large) URL" name="cover_l_url" required value=`${book.cover_l_url}`)

            label(class="formLabels" for="tags") Tags:
            div(class="formInputs" id="tags")
                for tag in tags
                    div(class="CheckBoxContainer")
                        if tag.checked
                            input(id=tag._id, value=tag._id, name="tag", type="checkbox", checked)
                        else
                            input(id=tag._id, value=tag._id, name="tag", type="checkbox")
                        label(for=tag._id) &nbsp;#{tag.name}

            div(class="formButtons")
                button(id="submit" type="submit") Submit
                a(class="alert" onclick=`confirmRedirect('${book.url}/delete')`) Delete

